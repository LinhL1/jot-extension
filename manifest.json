{
  "manifest_version": 3,
  "name": "Jot",
  "version": "1.0.0",
  "description": "Capture highlights and turn them into quick notes from any webpage.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Jot"
  }
}